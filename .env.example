TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=-100123456789
RTSP_URL=rtsp://admin:VERIFICATION_CODE@192.168.1.100:554/h264/ch01/main/av_stream

# How many minutes on the floor before alerting (default: 3)
FALL_THRESHOLD_MINUTES=3

# Don't send another alert for this many minutes after one was sent (default: 15)
ALERT_COOLDOWN_MINUTES=15

# How often to sample a frame in seconds (default: 5)
FRAME_INTERVAL_SECONDS=5

# Consecutive "not on floor" frames required before declaring all clear (default: 3)
NOT_ON_FLOOR_STREAK_MAX=3
